{
  "compilerOptions": {
    "target":            "ES2022",
    "module":            "CommonJS",
    "lib":               ["ES2022"],
    "outDir":            "./dist",
    "rootDir":           "./src",
    "strict":            false,
    "noImplicitAny":     false,
    "strictNullChecks":  true,
    "esModuleInterop":   true,
    "skipLibCheck":      true,
    "resolveJsonModule": true,
    "experimentalDecorators": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}

